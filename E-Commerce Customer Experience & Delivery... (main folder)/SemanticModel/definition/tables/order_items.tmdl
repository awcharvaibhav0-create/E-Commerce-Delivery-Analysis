	/// Total revenue per line item: product price + freight value in BRL
	column 'Item Revenue' =
			-- CC3: Total Item Revenue (BRL)
			-- Sums the unit product price and freight cost for this line item
			-- Represents the total amount billed to the customer for this item
			-- Both columns cleaned to numeric type in Power Query (Prompt 3.4)
			-- Format: Brazilian Real — R$ symbol, comma thousands, 2 decimal places
			order_items[price] + order_items[freight_value]
		dataType: decimal
		formatString: R$ #,##0.00
		lineageTag: d814d389-4277-423f-88a9-dc95f3059b34
		summarizeBy: sum

