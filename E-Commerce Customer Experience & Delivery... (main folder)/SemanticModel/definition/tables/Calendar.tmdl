	column Year-Month
		lineageTag: b746c3e5-2c30-4c5f-bb69-faa7f0fc56b1
		summarizeBy: none
		isNameInferred
		sourceColumn: [Year-Month]

		annotation SummarizationSetBy = Automatic

	partition Calendar = calculated
		mode: import
		source =
				ADDCOLUMNS(
				    CALENDAR(DATE(2016,1,1), DATE(2018,12,31)),
				
				    // ── 1. Year ───────────────────────────────────────────────────────────────────
				    "Year",
				        YEAR([Date]),
				
				    // ── 2. Month Number ───────────────────────────────────────────────────────────
				    "Month Number",
				        MONTH([Date]),
				
				    // ── 3. Month Name (January...December) ───────────────────────────────────────
				    "Month Name",
				        FORMAT([Date], "MMMM"),
				
				    // ── 4. Month Short (Jan...Dec) ────────────────────────────────────────────────
				    "Month Short",
				        FORMAT([Date], "MMM"),
				
				    // ── 5. Quarter Label (Q1..Q4) ─────────────────────────────────────────────────
				    "Quarter",
				        "Q" & CONVERT(INT((MONTH([Date])-1)/3)+1, STRING),
				
				    // ── 6. Quarter Number (1..4) ──────────────────────────────────────────────────
				    "Quarter Number",
				        INT((MONTH([Date])-1)/3)+1,
				
				    // ── 7. Week Number (ISO: Monday=start of week) ────────────────────────────────
				    "Week Number",
				        WEEKNUM([Date], 2),
				
				    // ── 8. Day Name (Monday...Sunday) ────────────────────────────────────────────
				    "Day Name",
				        FORMAT([Date], "DDDD"),
				
				    // ── 9. Day Number (1=Mon, 7=Sun) ──────────────────────────────────────────────
				    "Day Number",
				        WEEKDAY([Date], 2),
				
				    // ── 10. Is Weekend ────────────────────────────────────────────────────────────
				    // WEEKDAY mode 2: Mon=1...Sat=6, Sun=7 → >=6 means weekend
				    "Is Weekend",
				        IF(WEEKDAY([Date], 2) >= 6, "Weekend", "Weekday"),
				
				    // ── 11. Fiscal Year (April start) ────────────────────────────────────────────
				    // Apr 2016 onward = FY2016-17 | Jan-Mar 2016 = FY2015-16
				    "Fiscal Year",
				        IF(
				            MONTH([Date]) >= 4,
				            "FY" & YEAR([Date])     & "-" & RIGHT(CONVERT(YEAR([Date]) + 1, STRING), 2),
				            "FY" & (YEAR([Date])-1) & "-" & RIGHT(CONVERT(YEAR([Date]),     STRING), 2)
				        ),
				
				    // ── 12. Fiscal Quarter (April-start fiscal year) ──────────────────────────────
				    // Apr-Jun = FQ1 | Jul-Sep = FQ2 | Oct-Dec = FQ3 | Jan-Mar = FQ4
				    "Fiscal Quarter",
				        "FQ" & CONVERT(
				            SWITCH(
				                TRUE(),
				                MONTH([Date]) >= 4  && MONTH([Date]) <= 6,  1,
				                MONTH([Date]) >= 7  && MONTH([Date]) <= 9,  2,
				                MONTH([Date]) >= 10 && MONTH([Date]) <= 12, 3,
				                4
				            ),
				        STRING),
				
				    // ── 13. Year-Month (YYYY-MM format for chronological sort) ────────────────────
				    "Year-Month",
				        FORMAT([Date], "YYYY-MM")
				)

