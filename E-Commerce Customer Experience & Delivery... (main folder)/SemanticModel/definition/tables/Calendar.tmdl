table Calendar
	lineageTag: 2a7775c1-8a2f-4e91-aab4-d1bac912169c
	dataCategory: Time

	measure 'Is Top 5 Category' = ```
			
			VAR _CurrentRev = [Total Revenue]
			VAR _Threshold = 
			    MINX(
			        TOPN(5, VALUES(products[Category]), [Total Revenue], DESC), 
			        [Total Revenue]
			    )
			RETURN IF(_CurrentRev >= _Threshold, 1, 0)
			```
		formatString: 0
		lineageTag: 705d897d-34ca-4194-aa0a-0491c78b4edd

	measure 'Month-over-Month new customer growth rate' = ```
			
			VAR _Current = [New Customers]
			VAR _Previous = CALCULATE([New Customers], PREVIOUSMONTH('Calendar'[Date]))
			VAR _Growth = IF(NOT ISBLANK(_Current) && _Previous <> 0, 
			    DIVIDE(_Current - _Previous, _Previous, BLANK()), BLANK())
			RETURN _Growth
			```
		lineageTag: b6df2ca8-adb1-4250-86af-81119ae1db39

		annotation PBI_FormatHint = {"isGeneralNumber":true}

