	/// Days between order purchase and actual customer delivery
	column 'Delivery Days' =
			-- CC1: Delivery Duration
			-- Calculates whole days from order placement to actual delivery date
			-- DATEDIFF(start, end, DAY) handles time-portion differences automatically
			-- Returns NULL when order_delivered_customer_date is NULL (undelivered orders)
			-- NULL propagation is intentional here — use [Delivery Status] to segment nulls
			DATEDIFF(
			    orders[order_purchase_timestamp],
			    orders[order_delivered_customer_date],
			    DAY
			)
		dataType: int64
		lineageTag: 7acbe8b9-c0a0-4c79-b491-fe8b7e3d4e65
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	/// Delivery performance flag: Late / On Time / Not Delivered
	column 'Delivery Status' =
			-- CC2: Delivery Status Flag
			-- Three-tier classification of delivery performance
			-- ISBLANK check MUST come first — if delivered date is null,
			-- the greater-than comparison would silently return FALSE,
			-- producing incorrect 'On Time' results for undelivered orders
			IF(
			    -- Tier 1: Null guard — order not yet delivered or date not recorded
			    ISBLANK(orders[order_delivered_customer_date]),
			    "Not Delivered",
			    IF(
			        -- Tier 2: Actual delivery AFTER the promised estimated date → Late
			        orders[order_delivered_customer_date] > orders[order_estimated_delivery_date],
			        "Late",
			        -- Tier 3: Delivered ON or BEFORE estimated date → On Time
			        "On Time"
			    )
			)
		dataType: string
		lineageTag: 7d55ab5d-dc09-4a20-9276-f4734992e829
		summarizeBy: none

	/// Date-only key extracted from order_purchase_timestamp for Calendar relationship
	column 'Order Date' =
			-- Date bridge key: strips time from DateTime for clean join to Calendar[Date]
			-- Required because Calendar[Date] is type Date, but order_purchase_timestamp
			-- is DateTime — a DateTime-to-Date relationship only matches midnight rows
			DATE(
			    YEAR(orders[order_purchase_timestamp]),
			    MONTH(orders[order_purchase_timestamp]),
			    DAY(orders[order_purchase_timestamp])
			)
		dataType: dateTime
		formatString: dd/mm/yyyy
		lineageTag: cf6f4ce9-b0f5-4ea0-8293-af072802fe01
		summarizeBy: none

	partition orders = m
		mode: import
		source =
				let
				    // Step 1: Load all files from the project source folder
				    Source = Folder.Files("C:\PowerBi\project"),
				
				    // Step 2: Select the olist_orders_dataset CSV file
				    RawFile = Source{[#"Folder Path"="C:\PowerBi\project\",Name="olist_orders_dataset.csv"]}[Content],
				
				    // Step 3: Parse the CSV with correct delimiter and encoding
				    ImportedCSV = Csv.Document(RawFile,[Delimiter=",", Columns=8, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				
				    // Step 4: Promote first row as column headers
				    PromotedHeaders = Table.PromoteHeaders(ImportedCSV, [PromoteAllScalars=true]),
				
				    // Step 5: Convert all date/time columns to DateTime type
				    ChangedTypes = Table.TransformColumnTypes(PromotedHeaders,{
				        {"order_id",                        type text},
				        {"customer_id",                     type text},
				        {"order_status",                    type text},
				        {"order_purchase_timestamp",        type datetime},
				        {"order_approved_at",               type datetime},
				        {"order_delivered_carrier_date",    type datetime},
				        {"order_delivered_customer_date",   type datetime},
				        {"order_estimated_delivery_date",   type datetime}
				    }),
				
				    // Step 8: Remove rows where order_approved_at is null
				    RemovedNullApprovedAt = Table.SelectRows(ChangedTypes, each [order_approved_at] <> null)
				in
				    RemovedNullApprovedAt

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

