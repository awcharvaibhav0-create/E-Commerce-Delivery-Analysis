table products
	lineageTag: 6c2b3848-3510-4252-924f-59644efb23d2

	/// Count of distinct product categories that have revenue in the current filter context
	measure 'Active Categories' =
			-- Active Categories
			-- Counts distinct product categories with at least one sale in filter context
			-- Useful as a KPI card on the Product page header
			-- FILTER removes categories with blank/zero revenue (e.g. no orders in period)
			VAR _ActiveCats =
			    COUNTROWS(
			        FILTER(
			            VALUES(products[Category]),
			            NOT ISBLANK([Total Revenue])
			        )
			    )
			RETURN
			    IF(ISBLANK(_ActiveCats), 0, _ActiveCats)
		formatString: #,##0
		displayFolder: ðŸ“ˆ Advanced Metrics
		lineageTag: 87da6773-f189-4c10-a962-1b91036f1ccb

